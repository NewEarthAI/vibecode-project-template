{
  "mcpServers": {
    "supabase": {
      "command": "${NPX_PATH}",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=${SUPABASE_PROJECT_REF}",
        "--features=account,database,debugging,development,docs,functions,branching,storage"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "n8n": {
      "command": "${NPX_PATH}",
      "args": [
        "-y",
        "n8n-mcp@latest"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${N8N_API_URL}",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    },
    "github": {
      "command": "${HOME}/bin/github-mcp-server",
      "args": [
        "stdio"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },
    "redis": {
      "command": "${UVX_PATH}",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--host",
        "${REDIS_HOST}",
        "--port",
        "${REDIS_PORT}",
        "--username",
        "default",
        "--password",
        "${REDIS_PASSWORD}"
      ]
    },
    "airtable": {
      "command": "${NPX_PATH}",
      "args": [
        "-y",
        "@felores/airtable-mcp-server"
      ],
      "env": {
        "AIRTABLE_API_KEY": "${AIRTABLE_API_KEY}"
      }
    },
    "Context7": {
      "command": "${NPX_PATH}",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "chrome-devtools": {
      "command": "${NODE_PATH}",
      "args": ["${NPM_GLOBAL_ROOT}/chrome-devtools-mcp/build/src/bin/chrome-devtools-mcp.js"]
    },
    "playwright": {
      "command": "${NODE_PATH}",
      "args": ["${NPM_GLOBAL_ROOT}/@playwright/mcp/cli.js"]
    },
    "n8n-workflows_Docs": {
      "command": "${NPX_PATH}",
      "args": [
        "-y",
        "mcp-remote",
        "https://gitmcp.io/Zie619/n8n-workflows"
      ]
    }
  }
}
